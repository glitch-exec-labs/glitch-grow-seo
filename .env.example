# Glitch SEO — Public App Store app
# Copy to .env and fill real values. NEVER commit .env.

SHOPIFY_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SHOPIFY_API_SECRET=shpss_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SHOPIFY_APP_URL=https://grow.glitchexecutor.com
SCOPES=write_products,write_content,write_files,write_themes,write_translations,write_inventory,read_locales,read_product_listings,write_online_store_navigation
DATABASE_URL=postgresql://user:password@127.0.0.1:5432/shopify_app?schema=public
NODE_ENV=production
PORT=3102

# ─── AI SEO Agent ──────────────────────────────────────
# Central LLM kill switch. Default is "off" so a fresh production
# deploy CANNOT burn OpenAI credits without an explicit opt-in. Set to
# "live" in dev / when you're ready to pay for generations in prod.
AGENT_LLM_MODE=off

# OpenAI powers the planner (gpt-4o), all LLM generators (FAQ,
# llms.txt, copy rewrites, meta descriptions), the ClientMemory fact
# proposer, and memory embeddings (text-embedding-3-small).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small

# ─── Scheduled audits (optional) ──────────────────────
# POST /agent/cron/run is gated by BOTH of the below. Default is
# disabled; nothing runs on a cron schedule unless you opt in.
AGENT_CRON_ENABLED=false
AGENT_CRON_TOKEN=

# ─── Fleet testing (optional) ─────────────────────────
# Shared speed-bump token for /fleet status page + a pointer to the
# fleet config file (or inline JSON in FLEET_SITES_JSON).
ADMIN_TOKEN=
FLEET_CONFIG_PATH=./fleet.json
# FLEET_SITES_JSON=[{"id":"site-1","name":"Site 1","baseUrl":"https://example.com","platform":"astro"}]

# Shared bearer token every fleet Astro site uses to fetch from
# /api/fleet/:siteId/head. Generate a long random string and mirror it
# as GLITCH_SEO_TOKEN on each Astro site's deploy env.
FLEET_API_TOKEN=
