# ─── Secrets (NEVER commit) ────────────────────────────
.env
.env.local
.env.*.local
.env.production
*.pem
*.key
*.p12
*.pfx
*credentials*.json

# ─── Service-account key files ────────────────────────
credentials/
!credentials/.gitkeep

# ─── Python agent ─────────────────────────────────────
agent/.venv/
agent/.reports/
agent/**/__pycache__/
agent/*.egg-info/
agent/.pytest_cache/
agent/.mypy_cache/
agent/.ruff_cache/

# ─── Dependencies & build artifacts ────────────────────
node_modules/
.pnpm-store/
build/
dist/
/public/build/
/public/_dev
/extensions/*/dist
.next/
.react-router/
.cache/
.vite/
*.tsbuildinfo

# ─── Local DB (legacy dev) ────────────────────────────
*.sqlite
*.sqlite-journal
prisma/dev.db*
database.sqlite

# ─── Shopify CLI local state ──────────────────────────
.shopify/
.shopify.lock
shopify.web.toml.bak

# ─── Client-specific secrets that leak ────────────────
cli/shops.json
cli/shops.private.json
cli/clients/*.env

# ─── Fleet config (may hold private property URLs) ────
fleet.json
fleet.*.json
!fleet.example.json

# ─── OS / editor junk ─────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
.vscode/
.idea/

# ─── Logs ──────────────────────────────────────────────
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*

# ─── Temp ──────────────────────────────────────────────
tmp/
.tmp/
